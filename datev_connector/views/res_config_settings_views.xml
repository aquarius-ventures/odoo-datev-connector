<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="res_config_settings_view_form_datev" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.datev</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration" />
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="before">
                <div class="app_settings_block" data-string="DATEV Cloud" string="DATEV Cloud" data-key="datev_connector">
                    <h2>DATEV Cloud</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Connection Status</span>
                                <div class="text-muted">
                                    <field name="datev_connection_state" widget="statusbar" statusbar_visible="disconnected,connected" />
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <div class="o_form_label">Sandbox Mode</div>
                                <div class="text-muted">Use DATEV sandbox environment for testing</div>
                                <field name="datev_sandbox_mode" />
                            </div>
                        </div>
                    </div>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <div class="o_form_label">Client ID</div>
                                <field name="datev_client_id" class="o_light_label" />
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <div class="o_form_label">Client Secret</div>
                                <field name="datev_client_secret" password="True" class="o_light_label" />
                            </div>
                        </div>
                    </div>
                    <div class="row mt16 o_settings_container">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane" />
                            <div class="o_setting_right_pane">
                                <button
                                    name="action_datev_connect"
                                    type="object"
                                    string="Connect with DATEV"
                                    class="btn btn-primary"
                                    attrs="{'invisible': [('datev_connection_state', '=', 'connected')]}"
                                />
                                <button
                                    name="action_datev_disconnect"
                                    type="object"
                                    string="Disconnect"
                                    class="btn btn-secondary"
                                    attrs="{'invisible': [('datev_connection_state', '=', 'disconnected')]}"
                                />
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
