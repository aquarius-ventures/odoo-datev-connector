<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_datev_token_list" model="ir.ui.view">
        <field name="name">datev.token.list</field>
        <field name="model">datev.token</field>
        <field name="arch" type="xml">
            <tree string="DATEV Tokens" create="false">
                <field name="company_id" />
                <field name="state" widget="badge" decoration-success="state == 'connected'" decoration-danger="state == 'disconnected'" />
                <field name="token_expiry" />
                <field name="scope" />
            </tree>
        </field>
    </record>

    <record id="view_datev_token_form" model="ir.ui.view">
        <field name="name">datev.token.form</field>
        <field name="model">datev.token</field>
        <field name="arch" type="xml">
            <form string="DATEV Token" create="false">
                <header>
                    <button
                        name="action_disconnect"
                        type="object"
                        string="Disconnect"
                        class="btn-secondary"
                        invisible="state == 'disconnected'"
                    />
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="company_id" readonly="1" />
                            <field name="state" widget="badge" decoration-success="state == 'connected'" decoration-danger="state == 'disconnected'" />
                        </group>
                        <group>
                            <field name="token_expiry" />
                            <field name="scope" />
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_datev_token" model="ir.actions.act_window">
        <field name="name">DATEV Tokens</field>
        <field name="res_model">datev.token</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]" />
    </record>
</odoo>
