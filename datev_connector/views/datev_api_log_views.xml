<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_datev_api_log_list" model="ir.ui.view">
        <field name="name">datev.api.log.list</field>
        <field name="model">datev.api.log</field>
        <field name="arch" type="xml">
            <tree
                string="DATEV API Log"
                create="false"
                edit="false"
                default_order="request_ts desc"
            >
                <field name="request_ts" />
                <field name="method" />
                <field name="url" />
                <field
                    name="status_code"
                    decoration-success="status_code &lt; 400"
                    decoration-danger="status_code &gt;= 400"
                />
                <field name="x_global_transaction_id" optional="show" />
                <field name="v_cap_request_id" optional="show" />
                <field name="company_id" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="view_datev_api_log_form" model="ir.ui.view">
        <field name="name">datev.api.log.form</field>
        <field name="model">datev.api.log</field>
        <field name="arch" type="xml">
            <form string="DATEV API Log" create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="request_ts" />
                            <field name="method" />
                            <field name="url" />
                            <field name="company_id" />
                        </group>
                        <group>
                            <field name="response_ts" />
                            <field name="status_code" />
                            <field name="x_global_transaction_id" />
                            <field name="v_cap_request_id" />
                            <field name="error" />
                        </group>
                    </group>
                    <group string="Request Headers (Authorization geschwärzt)">
                        <field name="request_headers" nolabel="1" />
                    </group>
                    <group string="Response Body (nur Fehler/Statusabfragen)">
                        <field name="response_body" nolabel="1" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_datev_api_log_search" model="ir.ui.view">
        <field name="name">datev.api.log.search</field>
        <field name="model">datev.api.log</field>
        <field name="arch" type="xml">
            <search string="DATEV API Log">
                <field name="url" />
                <field name="x_global_transaction_id" />
                <field name="v_cap_request_id" />
                <filter
                    name="errors"
                    string="Fehler (4XX/5XX)"
                    domain="[('status_code', '&gt;=', 400)]"
                />
                <filter
                    name="today"
                    string="Heute"
                    domain="[('request_ts', '&gt;=', context_today().strftime('%Y-%m-%d'))]"
                />
            </search>
        </field>
    </record>

    <record id="action_datev_api_log" model="ir.actions.act_window">
        <field name="name">API Log</field>
        <field name="res_model">datev.api.log</field>
        <field name="view_mode">tree,form</field>
        <field name="groups_id" eval="[(4, ref('base.group_system'))]" />
    </record>
</odoo>
