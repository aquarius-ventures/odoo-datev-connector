<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_datev_employee_mapping_list" model="ir.ui.view">
        <field name="name">datev.employee.mapping.list</field>
        <field name="model">datev.employee.mapping</field>
        <field name="arch" type="xml">
            <tree string="DATEV Employee Mappings" editable="bottom">
                <field name="employee_id" />
                <field name="datev_personnel_number" />
                <field name="datev_consultant_number" optional="hide" />
            </tree>
        </field>
    </record>

    <record id="action_datev_employee_mapping" model="ir.actions.act_window">
        <field name="name">Employee Mappings</field>
        <field name="res_model">datev.employee.mapping</field>
        <field name="view_mode">tree</field>
    </record>
</odoo>
