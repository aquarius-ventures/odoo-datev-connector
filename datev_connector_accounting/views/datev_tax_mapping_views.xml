<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_datev_tax_mapping_list" model="ir.ui.view">
        <field name="name">datev.tax.mapping.list</field>
        <field name="model">datev.tax.mapping</field>
        <field name="arch" type="xml">
            <tree string="DATEV Tax Mappings" editable="bottom">
                <field name="company_id" column_invisible="1" />
                <field name="tax_id" />
                <field name="datev_bu_key" />
            </tree>
        </field>
    </record>

    <record id="action_datev_tax_mapping" model="ir.actions.act_window">
        <field name="name">Tax Mappings (BU-Schlüssel)</field>
        <field name="res_model">datev.tax.mapping</field>
        <field name="view_mode">tree</field>
        <field name="context">{"search_default_active": 1}</field>
    </record>
</odoo>
