<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_move_form_datev" model="ir.ui.view">
        <field name="name">account.move.form.datev</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <field name="datev_exported" invisible="1" />
                <field name="datev_job_state" invisible="1" />
                <button
                    name="action_datev_export_single"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-upload"
                    invisible="state != 'posted' or datev_job_state == 'pending'"
                >
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">DATEV</span>
                        <span
                            class="o_stat_text"
                            invisible="not datev_exported"
                        >Exported</span>
                        <span
                            class="o_stat_text"
                            invisible="datev_exported"
                        >Export</span>
                    </div>
                </button>
                <button
                    name="action_datev_refresh_job_status"
                    type="object"
                    class="oe_stat_button"
                    icon="fa-refresh"
                    invisible="datev_job_state != 'pending'"
                >
                    <div class="o_field_widget o_stat_info">
                        <span class="o_stat_text">DATEV</span>
                        <span class="o_stat_text">Pending...</span>
                    </div>
                </button>
            </xpath>
            <xpath expr="//sheet" position="before">
                <div
                    class="alert alert-danger mb-0"
                    role="alert"
                    invisible="datev_job_state != 'failed'"
                >
                    <strong>DATEV-Import fehlgeschlagen: </strong>
                    <field name="datev_job_error" readonly="1" />
                </div>
                <div
                    class="alert alert-info mb-0"
                    role="alert"
                    invisible="datev_job_state != 'pending'"
                >
                    DATEV verarbeitet den Buchungsstapel — der Status wird automatisch
                    aktualisiert (frühestens 60 s nach dem Upload).
                </div>
                <div
                    class="alert alert-success mb-0"
                    role="alert"
                    invisible="datev_job_state != 'succeeded'"
                >
                    In DATEV übernommen — der Buchungsstapel wurde erfolgreich verarbeitet.
                </div>
            </xpath>
        </field>
    </record>

    <record id="action_datev_refresh_jobs" model="ir.actions.server">
        <field name="name">DATEV: Job-Status aktualisieren</field>
        <field name="model_id" ref="account.model_account_move" />
        <field name="binding_model_id" ref="account.model_account_move" />
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field
            name="code"
        >action = records.action_datev_refresh_job_status()</field>
    </record>

    <!-- Customer invoices / vendor bills list (the list Community users
         actually see — view_move_tree is the journal-entries list). -->
    <record id="view_invoice_tree_datev" model="ir.ui.view">
        <field name="name">account.invoice.tree.datev</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_invoice_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='ref']" position="after">
                <field name="datev_exported" optional="hide" />
                <field
                    name="datev_job_state"
                    string="DATEV"
                    optional="show"
                    widget="badge"
                    decoration-success="datev_job_state == 'succeeded'"
                    decoration-warning="datev_job_state == 'pending'"
                    decoration-danger="datev_job_state == 'failed'"
                />
            </xpath>
        </field>
    </record>

    <record id="view_move_list_datev" model="ir.ui.view">
        <field name="name">account.move.list.datev</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='amount_total_signed']" position="after">
                <field name="datev_exported" optional="show" />
                <field name="datev_export_date" optional="hide" />
                <field
                    name="datev_job_state"
                    optional="show"
                    widget="badge"
                    decoration-success="datev_job_state == 'succeeded'"
                    decoration-warning="datev_job_state == 'pending'"
                    decoration-danger="datev_job_state == 'failed'"
                />
            </xpath>
        </field>
    </record>
</odoo>
