<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_datev_account_mapping_list" model="ir.ui.view">
        <field name="name">datev.account.mapping.list</field>
        <field name="model">datev.account.mapping</field>
        <field name="arch" type="xml">
            <tree string="DATEV Account Mappings" editable="bottom">
                <field name="account_id" />
                <field name="datev_account_number" />
                <field name="datev_cost_center" optional="show" />
            </tree>
        </field>
    </record>

    <record id="action_datev_account_mapping" model="ir.actions.act_window">
        <field name="name">Account Mappings</field>
        <field name="res_model">datev.account.mapping</field>
        <field name="view_mode">tree</field>
        <field name="context">{"search_default_active": 1}</field>
    </record>
</odoo>
