<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_datev_export_wizard_form" model="ir.ui.view">
        <field name="name">datev.export.wizard.form</field>
        <field name="model">datev.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Export to DATEV Cloud">
                <group>
                    <group string="Date Range">
                        <field name="date_from" />
                        <field name="date_to" />
                    </group>
                    <group string="Options">
                        <field name="export_mode" widget="radio" />
                        <field name="include_exported" />
                    </group>
                </group>
                <group string="Filter">
                    <field
                        name="journal_ids"
                        widget="many2many_tags"
                        options="{'no_create': True}"
                    />
                    <field
                        name="designation"
                        placeholder="z. B. Ausgangsrechnungen 01/2026"
                    />
                </group>
                <footer>
                    <button
                        name="action_export"
                        type="object"
                        string="Export"
                        class="btn-primary"
                    />
                    <button
                        string="Cancel"
                        class="btn-secondary"
                        special="cancel"
                    />
                </footer>
            </form>
        </field>
    </record>

    <record id="action_datev_export_wizard" model="ir.actions.act_window">
        <field name="name">Export to DATEV</field>
        <field name="res_model">datev.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
