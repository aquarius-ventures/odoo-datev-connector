<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="hr_employee_view_form_datev" model="ir.ui.view">
        <field name="name">hr.employee.form.datev</field>
        <field name="model">hr.employee</field>
        <field name="inherit_id" ref="hr.view_employee_form" />
        <field name="arch" type="xml">

            <!-- ── Pflichtfelder im Personal-Tab (grün) ───────────────────── -->
            <xpath expr="//page[@name='personal_information']//field[@name='birthday']" position="attributes">
                <attribute name="class">o_datev_required</attribute>
            </xpath>
            <xpath expr="//page[@name='personal_information']//field[@name='gender']" position="attributes">
                <attribute name="class">o_datev_required</attribute>
            </xpath>
            <xpath expr="//page[@name='personal_information']//field[@name='ssnid']" position="attributes">
                <attribute name="class">o_datev_required</attribute>
            </xpath>

            <!-- ── Optionale Felder im Personal-Tab (grau) ────────────────── -->
            <xpath expr="//page[@name='personal_information']//field[@name='place_of_birth']" position="attributes">
                <attribute name="class">o_datev_optional</attribute>
            </xpath>
            <xpath expr="//page[@name='personal_information']//field[@name='country_of_birth']" position="attributes">
                <attribute name="class">o_datev_optional</attribute>
            </xpath>
            <xpath expr="//page[@name='personal_information']//field[@name='marital']" position="attributes">
                <attribute name="class">o_datev_optional</attribute>
            </xpath>
            <xpath expr="//page[@name='personal_information']//field[@name='children']" position="attributes">
                <attribute name="class">o_datev_optional</attribute>
            </xpath>

            <!-- ── Neuer DATEV / LODAS Tab ────────────────────────────────── -->
            <xpath expr="//notebook" position="inside">
                <page string="DATEV / LODAS" name="datev_lodas"
                      groups="hr.group_hr_user">

                    <!-- Sync-Status -->
                    <group string="DATEV Cloud Sync">
                        <group>
                            <field name="datev_sync_enabled" widget="boolean_toggle" />
                            <field name="datev_last_sync" readonly="1"
                                   invisible="not datev_last_sync" />
                            <field name="datev_sync_created" readonly="1"
                                   invisible="not datev_sync_created" />
                        </group>
                    </group>

                    <div class="alert alert-danger mb-3" role="alert"
                         invisible="not datev_sync_error">
                        <strong>Sync-Fehler: </strong>
                        <field name="datev_sync_error" readonly="1" nolabel="1" />
                    </div>

                    <group string="Allgemein">
                        <group>
                            <field name="datev_personnel_number" class="o_datev_required" />
                            <field name="datev_cost_center" class="o_datev_optional" />
                        </group>
                    </group>

                    <group string="Steuer">
                        <group>
                            <field name="datev_tax_class" class="o_datev_required" />
                            <field name="datev_tax_id_number" class="o_datev_required" />
                        </group>
                        <group>
                            <field name="datev_church_tax" class="o_datev_optional" />
                        </group>
                    </group>

                    <group string="Sozialversicherung">
                        <group>
                            <field name="datev_health_insurance_name" class="o_datev_required" />
                            <field name="datev_health_insurance_type" class="o_datev_required" />
                        </group>
                        <group>
                            <field name="datev_child_allowance" class="o_datev_optional" />
                        </group>
                    </group>

                </page>
            </xpath>

        </field>
    </record>
</odoo>
